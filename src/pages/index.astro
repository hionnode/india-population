---
import '../styles/global.css';
import { CENSUS, REGION_ORDER, REGION_LABELS, REGION_COLORS } from '../data/census';
import PageNav from '../components/PageNav.astro';
import GrowthLines from '../components/GrowthLines.astro';
import PopPerSeat from '../components/PopPerSeat.astro';
import FreezePenalty from '../components/FreezePenalty.astro';

const firstYear = CENSUS[0].year;
const lastYear = CENSUS[CENSUS.length - 1].year;
const initialIndex = 0;
const ordinals = [
  'the first','the second','the third','the fourth','the fifth','the sixth','the seventh',
  'the eighth','the ninth','the tenth','the eleventh','the twelfth','the thirteenth','the fourteenth',
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,800;0,9..144,900;1,9..144,400;1,9..144,600&family=Jost:wght@300;400;500;600&family=Tiro+Devanagari+Hindi:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>The Present · वर्तमान · The Indian Census, {firstYear}–{lastYear}</title>
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <div class="page">

      <PageNav current={1} />

      <hr class="rule double" />

      <!-- Masthead -->
      <header class="masthead">
        <div class="masthead-copy">
          <p class="kicker">Part the First · Vol. I</p>
          <h1 class="title">
            <span class="title-en">The</span>
            <span class="title-en-b">Present</span>
            <span class="title-hi">वर्तमान</span>
          </h1>
          <p class="lede">
            One billion people, five hundred and forty-three seats, and a
            map drawn in <em>1971</em>. A fourteen-census study of the
            regional shift that made the current allocation indefensible —
            and the state-level penalty the freeze now extracts.
          </p>
        </div>
        <div class="masthead-figure" aria-hidden="true">
          <div class="glyph">§</div>
          <div class="figure-no">No.<br /><b>I</b></div>
        </div>
      </header>

      <hr class="rule" />

      <!-- Scrollytelling pin: year + chart + rail freeze in the centre
           of the viewport while page scroll advances the census year.   -->
      <section class="scrollytell" id="scrollytell">
        <div class="scrollytell-inner">
          <!-- The year, enormous -->
          <section class="year-section">
            <div class="year-label-col">
              <span class="smallcaps">the year ·&nbsp;<span class="hi">वर्ष</span></span>
              <span class="year-ord" id="year-ord">{ordinals[initialIndex]} census</span>
            </div>
            <div class="year-big-col">
              <span class="year-big" id="year-label" aria-live="polite">{CENSUS[initialIndex].year}{' '}</span>
              <span class="estimated-tag" id="estimated-badge" hidden>
                <span class="est-mark">†</span> figure reconstructed
              </span>
            </div>
            <div class="year-total-col">
              <span class="smallcaps">total India</span>
              <span class="total-num" id="total-pop">—</span>
              <span class="total-unit">million souls</span>
            </div>
          </section>

          <!-- Fig. 1 — regional shares -->
          <figure class="chart-figure">
            <figcaption class="fig-head">
              <span class="fig-label">Fig. 1</span>
              <span class="fig-title">Share of the all-India total, by region</span>
              <span class="fig-unit">— per cent —</span>
            </figcaption>
            <div id="chart" class="chart"></div>
          </figure>

          <hr class="rule" />

          <!-- Timeline: read-only progress rail in scroll mode,
               draggable slider in reduced-motion fallback.            -->
          <section class="timeline">
            <div class="timeline-head">
              <span class="smallcaps timeline-hint timeline-hint-scroll">scroll the census year</span>
              <span class="smallcaps timeline-hint timeline-hint-drag">drag the census year</span>
              <span class="smallcaps dim"><span class="hi">वर्ष सरकाएँ</span></span>
            </div>
            <div class="slider-wrap">
              <input
                type="range"
                id="year-slider"
                min="0"
                max={CENSUS.length - 1}
                step="1"
                value={initialIndex}
                aria-label="Census year"
              />
              <div class="rail" aria-hidden="true">
                <div class="rail-fill" id="rail-fill"></div>
                {CENSUS.map((row, i) => (
                  <div
                    class={`tick ${row.estimated ? 'tick-est' : ''}`}
                    data-idx={i}
                    style={`left: ${(i / (CENSUS.length - 1)) * 100}%`}
                  >
                    <span class="tick-mark"></span>
                    <span class={`tick-year ${[0, 4, 7, 10, 13].includes(i) ? 'major' : ''}`}>
                      {[0, 4, 7, 10, 13].includes(i) ? row.year : ''}
                    </span>
                  </div>
                ))}
                <span class="rail-end" aria-hidden="true"></span>
              </div>
            </div>
          </section>
        </div>
      </section>

      <hr class="rule" />

      <!-- The constitutional bargain, and the freeze -->
      <aside class="bargain">
        <div class="bargain-mark" aria-hidden="true">§</div>
        <div class="bargain-body">
          <span class="smallcaps">A bargain, and its expiry date</span>
          <h3 class="bargain-title">
            The Constitution promised a redraw every ten years.
            <span class="bargain-hi hi">हर दशक का वादा</span>
          </h3>
          <p class="bargain-text">
            <b>Articles 81 &amp; 82</b> instructed Parliament to re-allot
            Lok Sabha seats after each census, so that no vote weighed more
            than another. In <b>1976</b>, mid-Emergency, with the South's
            family-planning drive working and the North's faltering,
            Mrs Gandhi's government passed the <b>42nd Amendment</b> and
            froze the allocation at 1971 figures. In <b>2001</b>, the Vajpayee
            NDA passed the <b>84th Amendment</b> and extended the freeze to
            the first census taken after <b>2026</b>. The decadal promise is
            now half a century overdue.
          </p>
          <div class="bargain-meta">
            <span><b>1976</b> · 42nd Amdt. · freeze begins</span>
            <span class="bargain-sep">◇</span>
            <span><b>2001</b> · 84th Amdt. · extended to 2026</span>
            <span class="bargain-sep">◇</span>
            <a class="bargain-link" href="/history/">read the full history →</a>
          </div>
        </div>
      </aside>

      <hr class="rule double" />

      <!-- Chapter II opener -->
      <section class="chapter-opener">
        <span class="smallcaps">Part the Second</span>
        <h2 class="chapter-title">
          <span class="chapter-numeral">ii.</span>
          Why redraw
          <span class="chapter-hi hi">क्यों पुनर्रचना</span>
        </h2>
        <p class="chapter-lede">
          Three figures follow. When each region's growth peaked, how many
          people now answer to a single Lok Sabha seat, and how far each
          state now sits from the population behind it.
        </p>
      </section>

      <hr class="rule" />

      <GrowthLines />

      <hr class="rule" />

      <!-- Fig. 3 lede — the 14.24L number with a political face -->
      <aside class="fig-lede">
        <p>
          On the 2011 count, each Lok Sabha seat ought to answer to roughly
          <b>14.24 lakh Indians</b>. A voter in Kerala sends one MP for every
          <b>16.7 lakh</b> neighbours; a voter in Rajasthan, one for every
          <b>27.4 lakh</b>; a voter in Bihar, one for every
          <b>26.0 lakh</b>. The gap is not arithmetic. It is the 1976 freeze,
          compounding for half a century.
        </p>
      </aside>

      <PopPerSeat />

      <hr class="rule" />

      <FreezePenalty />

      <hr class="rule double" />

      <!-- Dramatis personae (region legend) -->
      <section class="dramatis">
        <h2 class="section-heading">
          <span class="section-no">iii.</span>
          <span>Dramatis personae</span>
          <span class="section-hi hi">चार क्षेत्र</span>
        </h2>
        <div class="regions-grid">
          {REGION_ORDER.map((region, i) => (
            <article class="region" style={`--region-color: ${REGION_COLORS[region]}`}>
              <div class="region-head">
                <span class="region-num">{String(i + 1).padStart(2, '0')}</span>
                <div>
                  <h3 class="region-name">{REGION_LABELS[region].en}</h3>
                  <span class="region-hi hi">{REGION_LABELS[region].hi}</span>
                </div>
                <span class="region-swatch"></span>
              </div>
              <p class="region-states">{REGION_LABELS[region].states}</p>
            </article>
          ))}
          <span aria-hidden="true" class="grid-end"></span>
        </div>
      </section>

      <hr class="rule double" />

      <!-- Transition to Page 2 -->
      <aside class="next-step">
        <span class="smallcaps">continue reading</span>
        <a href="/history/" class="next-link">
          <span class="next-arrow">→</span>
          <span class="next-title">Seven Dates</span>
          <span class="next-subtitle hi">सात तिथियाँ</span>
        </a>
        <p class="next-blurb">
          The map is frozen to 1971. That is a fact, not an accident.
          Read how it came to be frozen — and by whom.
        </p>
      </aside>

      <hr class="rule" />

      <footer class="colophon">
        <div class="colophon-col">
          <span class="smallcaps">§ source</span>
          <p>
            Figures for <b>1901–2011</b> are taken directly from the Census of India,
            Table A-02, <em>Decadal Variation in Population 1901–2011</em>, as published
            by the Office of the Registrar General &amp; Census Commissioner. Values are
            already backfilled to post-2000 state boundaries; districts that became
            Pakistan and Bangladesh are excluded throughout.
            <a
              href="https://censusindia.gov.in/nada/index.php/catalog/43333"
              target="_blank"
              rel="noopener noreferrer"
            >— NADA 43333 →</a>
          </p>
        </div>
        <div class="colophon-col">
          <span class="smallcaps">† on the two estimated years</span>
          <p>
            <b>1881 and 1891</b> are reconstructions. The A-02 decadal table begins in
            1901; earlier enumerations were published by British province, not by
            modern state. These two years scale the 1901 modern-India total by the
            contemporaneous British-India-Empire ratio; regional shares are held
            constant at 1901 proportions.
          </p>
        </div>
      </footer>

      <div class="running-foot">
        <span class="eyebrow">Set in Fraunces &amp; Tiro Devanagari Hindi</span>
        <span class="eyebrow dot">◇</span>
        <span class="eyebrow">Composed on cream</span>
      </div>
    </div>

    <script>
      import ApexCharts from 'apexcharts';
      import {
        CENSUS,
        REGION_ORDER,
        REGION_LABELS,
        REGION_COLORS,
        percentShare,
        decadalGrowth,
        type Region,
      } from '../data/census';
      import { sortedByPopPerSeat, LOKSABHA_META, shareRows } from '../data/loksabha';

      const sliderEl = document.getElementById('year-slider') as HTMLInputElement;
      const yearLabelEl = document.getElementById('year-label')!;
      const yearOrdEl = document.getElementById('year-ord')!;
      const estimatedBadgeEl = document.getElementById('estimated-badge')!;
      const totalPopEl = document.getElementById('total-pop')!;

      const ordinals = [
        'the first','the second','the third','the fourth','the fifth','the sixth','the seventh',
        'the eighth','the ninth','the tenth','the eleventh','the twelfth','the thirteenth','the fourteenth',
      ];

      const seriesFor = (idx: number) =>
        REGION_ORDER.map((r) => +percentShare(CENSUS[idx], r).toFixed(2));

      /* ─────────────────────────────────────────────────────────────
         Fig. 1 — Interactive share-by-region bars
         ───────────────────────────────────────────────────────────── */
      const options: ApexCharts.ApexOptions = {
        chart: {
          type: 'bar',
          height: 440,
          fontFamily: '"Jost", "Tiro Devanagari Hindi", system-ui, sans-serif',
          toolbar: { show: false },
          // Animations disabled: scroll-driven updates need instant snap,
          // not 420ms tweens that queue up on every frame.
          animations: { enabled: false },
          background: 'transparent',
          parentHeightOffset: 0,
        },
        // On phones the pinned frame is short. A 440px chart plus the giant
        // year + rail overflows. Shrink so all three stay on-screen.
        responsive: [
          { breakpoint: 760, options: { chart: { height: 220 } } },
        ],
        series: [{ name: 'Share of India', data: seriesFor(0) }],
        plotOptions: {
          bar: {
            columnWidth: '42%',
            borderRadius: 0,
            distributed: true,
            dataLabels: { position: 'top' },
          },
        },
        colors: REGION_ORDER.map((r) => REGION_COLORS[r]),
        states: {
          hover: { filter: { type: 'darken', value: 0.88 } },
          active: { filter: { type: 'none' } },
        },
        stroke: { show: true, width: 1, colors: ['#1a1510'] },
        xaxis: {
          categories: REGION_ORDER.map(
            (r) => `${REGION_LABELS[r].en.toUpperCase()}  ·  ${REGION_LABELS[r].hi}`,
          ),
          labels: {
            style: {
              fontSize: '11px',
              fontWeight: 500,
              fontFamily: '"Jost", "Tiro Devanagari Hindi", sans-serif',
              colors: '#1a1510',
            },
            offsetY: 4,
          },
          axisBorder: { show: true, color: '#1a1510', height: 1 },
          axisTicks: { show: false },
          crosshairs: { show: false },
        },
        yaxis: {
          min: 0,
          max: 60,
          tickAmount: 6,
          labels: {
            formatter: (val: number) => `${val.toFixed(0)}%`,
            style: { fontSize: '11px', fontFamily: '"Jost", sans-serif', colors: '#6b5d4f' },
          },
          axisBorder: { show: false },
        },
        dataLabels: {
          enabled: true,
          formatter: (val: number) => `${val.toFixed(1)}`,
          offsetY: -24,
          style: {
            fontSize: '20px',
            fontWeight: 700,
            fontFamily: '"Fraunces", serif',
            colors: ['#1a1510'],
          },
        },
        legend: { show: false },
        grid: {
          borderColor: '#d8cdb8',
          strokeDashArray: 2,
          yaxis: { lines: { show: true } },
          xaxis: { lines: { show: false } },
          padding: { top: 24, right: 16, bottom: 0, left: 8 },
        },
        tooltip: {
          custom: ({ dataPointIndex }) => {
            const idx = Number(sliderEl.value);
            const row = CENSUS[idx];
            const region = REGION_ORDER[dataPointIndex] as Region;
            const share = percentShare(row, region);
            const abs = row.regions[region];
            const label = REGION_LABELS[region];
            const color = REGION_COLORS[region];
            const estTag = row.estimated
              ? `<div style="font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#8c2e1a;margin-top:6px;font-family:Jost,sans-serif">† reconstructed figure</div>`
              : '';
            return `
              <div style="padding:14px 16px;min-width:240px;background:#f5efe3;border:1px solid #1a1510;box-shadow:4px 4px 0 0 #1a1510;font-family:'Jost',sans-serif;color:#1a1510">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
                  <span style="width:10px;height:10px;background:${color};border:1px solid #1a1510;display:inline-block"></span>
                  <span style="font-family:'Fraunces',serif;font-weight:700;font-size:16px">${label.en}</span>
                  <span style="font-family:'Tiro Devanagari Hindi',serif;font-size:13px;color:#6b5d4f">${label.hi}</span>
                </div>
                <div style="font-size:10.5px;color:#6b5d4f;margin-bottom:10px;line-height:1.4;letter-spacing:0.01em">${label.states}</div>
                <div style="display:flex;align-items:baseline;gap:12px;border-top:1px solid #1a1510;padding-top:8px">
                  <span style="font-family:'Fraunces',serif;font-size:32px;font-weight:700;line-height:1">${share.toFixed(1)}<span style="font-size:18px;font-weight:500">%</span></span>
                  <div style="font-size:11px;color:#6b5d4f;line-height:1.3">
                    of India<br/><b style="color:#1a1510">${abs.toFixed(1)}M</b> in ${row.year}
                  </div>
                </div>
                ${estTag}
              </div>
            `;
          },
        },
      };

      const chart = new ApexCharts(document.querySelector('#chart')!, options);
      chart.render();

      /* ─────────────────────────────────────────────────────────────
         Fig. 2 — Decadal growth-rate lines by region
         ───────────────────────────────────────────────────────────── */
      const growthSeries = REGION_ORDER.map((r) => ({
        name: REGION_LABELS[r].en,
        data: decadalGrowth(r).map((p) => ({ x: String(p.year), y: +p.pct.toFixed(2) })),
      }));

      const growthChart = new ApexCharts(document.querySelector('#growth-chart')!, {
        chart: {
          type: 'line',
          height: 420,
          fontFamily: '"Jost", "Tiro Devanagari Hindi", system-ui, sans-serif',
          toolbar: { show: false },
          background: 'transparent',
          animations: { enabled: true, speed: 500 },
          parentHeightOffset: 0,
        },
        series: growthSeries,
        colors: REGION_ORDER.map((r) => REGION_COLORS[r]),
        stroke: { width: [2.5, 2.5, 3.5, 2.5, 1.5], curve: 'straight', dashArray: [0, 0, 0, 0, 4] },
        markers: { size: 4, strokeWidth: 1, strokeColors: '#1a1510', hover: { size: 7 } },
        dataLabels: { enabled: false },
        xaxis: {
          type: 'category',
          labels: { style: { fontSize: '11px', fontFamily: '"Jost",sans-serif', colors: '#1a1510' } },
          axisBorder: { show: true, color: '#1a1510' },
          axisTicks: { show: false },
          title: { text: 'CENSUS YEAR', style: { fontSize: '10px', color: '#6b5d4f', fontWeight: 500 }, offsetY: 4 },
        },
        yaxis: {
          labels: {
            formatter: (v: number) => `${v.toFixed(0)}%`,
            style: { fontSize: '11px', fontFamily: '"Jost",sans-serif', colors: '#6b5d4f' },
          },
          title: { text: '% growth per decade', style: { fontSize: '11px', color: '#6b5d4f', fontWeight: 500 } },
          min: 0,
        },
        legend: {
          position: 'top',
          horizontalAlign: 'left',
          fontFamily: '"Jost",sans-serif',
          fontSize: '12px',
          labels: { colors: '#1a1510' },
          markers: { size: 8, strokeWidth: 1, shape: 'square' },
          itemMargin: { horizontal: 14, vertical: 4 },
          offsetY: -4,
        },
        grid: {
          borderColor: '#d8cdb8',
          strokeDashArray: 2,
          padding: { top: 10, right: 24, bottom: 0, left: 8 },
        },
        annotations: {
          points: [
            {
              x: '1971',
              y: decadalGrowth('South').find((p) => p.year === 1971)!.pct,
              marker: { size: 0 },
              label: {
                text: "South's peak",
                borderWidth: 0, offsetY: -10,
                style: { color: '#3d5c3d', background: 'transparent', fontFamily: '"Fraunces",serif', fontSize: '12px', fontWeight: 600 },
              },
            },
            {
              x: '1991',
              y: decadalGrowth('North').find((p) => p.year === 1991)!.pct,
              marker: { size: 0 },
              label: {
                text: "North's peak",
                borderWidth: 0, offsetY: -10,
                style: { color: '#8c2e1a', background: 'transparent', fontFamily: '"Fraunces",serif', fontSize: '12px', fontWeight: 600 },
              },
            },
          ],
        },
        tooltip: {
          shared: true, intersect: false,
          custom: ({ dataPointIndex, w }) => {
            const year = String(w.globals.categoryLabels[dataPointIndex]);
            const rows = w.globals.series
              .map((s: number[], i: number) => {
                const name = w.globals.seriesNames[i];
                const color = w.globals.colors[i];
                return `<div style="display:flex;gap:8px;align-items:baseline;font-size:12px">
                  <span style="width:8px;height:8px;background:${color};border:1px solid #1a1510;display:inline-block"></span>
                  <span style="flex:1">${name}</span>
                  <b style="font-family:'Fraunces',serif;font-size:14px">${s[dataPointIndex]?.toFixed(1)}%</b>
                </div>`;
              })
              .join('');
            return `<div style="padding:10px 14px;min-width:220px;background:#f5efe3;border:1px solid #1a1510;box-shadow:4px 4px 0 0 #1a1510;font-family:'Jost',sans-serif;color:#1a1510">
              <div style="font-family:'Fraunces',serif;font-weight:700;font-size:16px;margin-bottom:6px;border-bottom:1px solid #1a1510;padding-bottom:4px">${year}</div>
              ${rows}
            </div>`;
          },
        },
      });
      growthChart.render();

      /* ─────────────────────────────────────────────────────────────
         Fig. 3 — Population per seat (horizontal bars)
         ───────────────────────────────────────────────────────────── */
      const popPerSeatSorted = sortedByPopPerSeat();
      const popSeatLakhs = popPerSeatSorted.map((s) => ({
        x: s.name,
        y: +(s.popPerSeat / 100_000).toFixed(2),
      }));
      const popSeatColors = popPerSeatSorted.map((s) => REGION_COLORS[s.region]);
      const idealLakh = LOKSABHA_META.delimitationAvgConstituency / 100_000;

      const popSeatChart = new ApexCharts(document.querySelector('#pop-per-seat-chart')!, {
        chart: {
          type: 'bar',
          height: 820,
          fontFamily: '"Jost", "Tiro Devanagari Hindi", system-ui, sans-serif',
          toolbar: { show: false },
          background: 'transparent',
          parentHeightOffset: 0,
        },
        colors: popSeatColors,
        series: [{ name: 'Lakh per seat', data: popSeatLakhs }],
        plotOptions: {
          bar: {
            horizontal: true,
            barHeight: '72%',
            borderRadius: 0,
            distributed: true,
            dataLabels: { position: 'top' },
          },
        },
        stroke: { show: true, width: 0.5, colors: ['#1a1510'] },
        dataLabels: {
          enabled: true,
          formatter: (v: number) => v.toFixed(1),
          offsetX: 28,
          style: { fontSize: '11px', fontFamily: '"Fraunces",serif', fontWeight: 600, colors: ['#1a1510'] },
        },
        xaxis: {
          labels: {
            formatter: (v: string) => `${Number(v).toFixed(0)}L`,
            style: { fontSize: '11px', fontFamily: '"Jost",sans-serif', colors: '#6b5d4f' },
          },
          axisBorder: { show: true, color: '#1a1510' },
          axisTicks: { show: false },
          title: { text: 'LAKH OF PEOPLE PER SEAT', style: { fontSize: '10px', color: '#6b5d4f', fontWeight: 500 }, offsetY: 4 },
        },
        yaxis: {
          labels: { style: { fontSize: '10.5px', fontFamily: '"Jost",sans-serif', colors: '#1a1510' } },
        },
        legend: { show: false },
        grid: {
          borderColor: '#d8cdb8',
          strokeDashArray: 2,
          xaxis: { lines: { show: true } },
          yaxis: { lines: { show: false } },
          padding: { top: 0, right: 40, bottom: 0, left: 8 },
        },
        annotations: {
          xaxis: [
            {
              x: idealLakh,
              borderColor: '#8c2e1a',
              strokeDashArray: 4,
              borderWidth: 1.5,
              label: {
                text: `ideal · ${idealLakh.toFixed(2)}L`,
                orientation: 'horizontal', position: 'top', offsetY: -6, borderWidth: 0,
                style: { color: '#8c2e1a', background: '#f5efe3', fontFamily: '"Fraunces",serif', fontSize: '11px', fontWeight: 600, padding: { left: 6, right: 6, top: 2, bottom: 2 } },
              },
            },
          ],
        },
        tooltip: {
          custom: ({ dataPointIndex }: any) => {
            const row = popPerSeatSorted[dataPointIndex];
            const color = REGION_COLORS[row.region];
            return `<div style="padding:12px 14px;min-width:220px;background:#f5efe3;border:1px solid #1a1510;box-shadow:4px 4px 0 0 #1a1510;font-family:'Jost',sans-serif;color:#1a1510">
              <div style="display:flex;gap:8px;align-items:center;margin-bottom:4px">
                <span style="width:10px;height:10px;background:${color};border:1px solid #1a1510;display:inline-block"></span>
                <span style="font-family:'Fraunces',serif;font-weight:700;font-size:15px">${row.name}</span>
              </div>
              <div style="font-size:10.5px;color:#6b5d4f;margin-bottom:8px;letter-spacing:0.02em">${REGION_LABELS[row.region].en}</div>
              <div style="border-top:1px solid #1a1510;padding-top:6px;display:flex;justify-content:space-between;gap:12px">
                <div><div style="font-size:10px;color:#6b5d4f;text-transform:uppercase;letter-spacing:0.14em">per seat</div>
                <b style="font-family:'Fraunces',serif;font-size:20px">${(row.popPerSeat/100_000).toFixed(1)}L</b></div>
                <div><div style="font-size:10px;color:#6b5d4f;text-transform:uppercase;letter-spacing:0.14em">seats</div>
                <b style="font-family:'Fraunces',serif;font-size:20px">${row.currentSeats}</b></div>
              </div>
            </div>`;
          },
        },
      });
      popSeatChart.render();

      /* ─────────────────────────────────────────────────────────────
         Fig. 4 — The Freeze Penalty (diverging bars)
         ───────────────────────────────────────────────────────────── */
      const freezeSorted = [...shareRows()].sort((a, b) => b.gapCurrent - a.gapCurrent);
      const freezeColors = freezeSorted.map((r) => REGION_COLORS[r.region]);

      const freezeChart = new ApexCharts(document.querySelector('#freeze-penalty-chart')!, {
        chart: {
          type: 'bar',
          height: 820,
          fontFamily: '"Jost", "Tiro Devanagari Hindi", system-ui, sans-serif',
          toolbar: { show: false },
          background: 'transparent',
          parentHeightOffset: 0,
        },
        colors: freezeColors,
        series: [{
          name: 'Δ pp',
          data: freezeSorted.map((r) => ({ x: r.name, y: +r.gapCurrent.toFixed(2) })),
        }],
        plotOptions: {
          bar: {
            horizontal: true,
            barHeight: '72%',
            borderRadius: 0,
            distributed: true,
            dataLabels: { position: 'top' },
          },
        },
        stroke: { show: true, width: 0.5, colors: ['#1a1510'] },
        dataLabels: {
          enabled: true,
          formatter: (v: number) => (v > 0 ? `+${v.toFixed(2)}` : v.toFixed(2)),
          offsetX: 26,
          style: { fontSize: '11px', fontFamily: '"Fraunces",serif', fontWeight: 600, colors: ['#1a1510'] },
        },
        xaxis: {
          labels: {
            formatter: (v: string) => `${Number(v) > 0 ? '+' : ''}${Number(v).toFixed(1)}`,
            style: { fontSize: '11px', fontFamily: '"Jost",sans-serif', colors: '#6b5d4f' },
          },
          axisBorder: { show: true, color: '#1a1510' },
          axisTicks: { show: false },
          title: { text: 'POPULATION SHARE MINUS SEAT SHARE (pp)', style: { fontSize: '10px', color: '#6b5d4f', fontWeight: 500 }, offsetY: 4 },
        },
        yaxis: {
          labels: { style: { fontSize: '10.5px', fontFamily: '"Jost",sans-serif', colors: '#1a1510' } },
        },
        legend: { show: false },
        grid: {
          borderColor: '#d8cdb8',
          strokeDashArray: 2,
          xaxis: { lines: { show: true } },
          yaxis: { lines: { show: false } },
          padding: { top: 0, right: 44, bottom: 0, left: 8 },
        },
        annotations: {
          xaxis: [
            { x: 0, borderColor: '#1a1510', strokeDashArray: 0, borderWidth: 1.5 },
          ],
        },
        tooltip: {
          custom: ({ dataPointIndex }: any) => {
            const r = freezeSorted[dataPointIndex];
            const color = REGION_COLORS[r.region];
            const sign = r.gapCurrent > 0 ? '+' : '';
            const direction = r.gapCurrent > 0 ? 'under-seated' : r.gapCurrent < 0 ? 'over-seated' : 'at parity';
            return `<div style="padding:12px 14px;min-width:230px;background:#f5efe3;border:1px solid #1a1510;box-shadow:4px 4px 0 0 #1a1510;font-family:'Jost',sans-serif;color:#1a1510">
              <div style="display:flex;gap:8px;align-items:center;margin-bottom:4px">
                <span style="width:10px;height:10px;background:${color};border:1px solid #1a1510;display:inline-block"></span>
                <span style="font-family:'Fraunces',serif;font-weight:700;font-size:15px">${r.name}</span>
              </div>
              <div style="font-size:10.5px;color:#6b5d4f;margin-bottom:8px;letter-spacing:0.02em">Population: ${r.popShare.toFixed(2)}% · Seats: ${r.seatShareCurrent.toFixed(2)}%</div>
              <div style="border-top:1px solid #1a1510;padding-top:8px">
                <div style="font-size:10px;color:#6b5d4f;text-transform:uppercase;letter-spacing:0.14em">${direction}</div>
                <b style="font-family:'Fraunces',serif;font-size:22px;color:${r.gapCurrent > 0 ? '#8c2e1a' : r.gapCurrent < 0 ? '#1f4d54' : '#6b5d4f'}">${sign}${r.gapCurrent.toFixed(2)}<span style="font-size:13px;color:#6b5d4f;font-weight:500">&nbsp;pp</span></b>
              </div>
            </div>`;
          },
        },
      });
      freezeChart.render();

      /* ─────────────────────────────────────────────────────────────
         Staggered entrance + slider wiring
         ───────────────────────────────────────────────────────────── */
      requestAnimationFrame(() => {
        document.body.classList.add('ready');
      });

      const railFillEl = document.getElementById('rail-fill')!;
      const scrollytellEl = document.getElementById('scrollytell')!;
      const tickEls = Array.from(
        document.querySelectorAll<HTMLElement>('.rail .tick'),
      );
      const lastIdx = CENSUS.length - 1;
      let currentIdx = -1;

      const update = (idx: number) => {
        if (idx === currentIdx) return;
        currentIdx = idx;
        const row = CENSUS[idx];
        yearLabelEl.textContent = String(row.year);
        yearOrdEl.textContent = `${ordinals[idx]} census`;
        estimatedBadgeEl.hidden = !row.estimated;
        totalPopEl.textContent = row.totalIndiaMillions.toFixed(1);
        chart.updateSeries([{ name: 'Share of India', data: seriesFor(idx) }]);

        // Keep the hidden range input in sync so tooltip & a11y read the
        // current year, and so the reduced-motion fallback starts coherent.
        if (sliderEl.value !== String(idx)) sliderEl.value = String(idx);

        // Read-only progress rail: fill bar + active-tick highlight.
        railFillEl.style.width = `${(idx / lastIdx) * 100}%`;
        for (let i = 0; i < tickEls.length; i++) {
          tickEls[i].classList.toggle('tick-current', i === idx);
        }

        yearLabelEl.classList.remove('year-flash');
        void (yearLabelEl as HTMLElement).offsetWidth;
        yearLabelEl.classList.add('year-flash');
      };

      update(Number(sliderEl.value));

      /* ─────────────────────────────────────────────────────────────
         Scroll-driven year controller
         ─ IntersectionObserver gates the scroll listener so the rest
           of the page costs nothing.
         ─ rAF throttles to one read per frame.
         ─ prefers-reduced-motion users get the original drag slider.
         ───────────────────────────────────────────────────────────── */
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

      const setupDragMode = () => {
        document.body.classList.add('reduced-motion');
        sliderEl.addEventListener('input', () => update(Number(sliderEl.value)));
      };

      const setupScrollMode = () => {
        let inZone = false;
        let ticking = false;
        let trackTop = 0;
        let trackHeight = 0;
        let viewportH = 0;

        const measure = () => {
          const rect = scrollytellEl.getBoundingClientRect();
          trackTop = rect.top + window.scrollY;
          trackHeight = scrollytellEl.offsetHeight;
          viewportH = window.innerHeight;
        };

        const tick = () => {
          ticking = false;
          const scrollable = trackHeight - viewportH;
          if (scrollable <= 0) return;
          const raw = (window.scrollY - trackTop) / scrollable;
          // 2% dead-zones at top and bottom so first/last years don't
          // trigger while half off-screen.
          const progress = Math.max(0, Math.min(1, (raw - 0.02) / 0.96));
          const idx = Math.max(0, Math.min(lastIdx, Math.floor(progress * CENSUS.length)));
          update(idx);
        };

        const onScroll = () => {
          if (!inZone || ticking) return;
          ticking = true;
          requestAnimationFrame(tick);
        };

        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              inZone = entry.isIntersecting;
              if (inZone) tick();
            }
          },
          { rootMargin: '0px 0px 0px 0px', threshold: 0 },
        );
        io.observe(scrollytellEl);

        let resizeT: number | undefined;
        const onResize = () => {
          if (resizeT) window.clearTimeout(resizeT);
          resizeT = window.setTimeout(() => {
            measure();
            tick();
          }, 120);
        };

        // Keyboard a11y: arrow / Home / End on the hidden input scrolls
        // the page to the matching segment.
        sliderEl.addEventListener('keydown', (ev) => {
          let next: number | null = null;
          // Smooth for one-beat moves (reads as a confident hop). Instant
          // for jump-to-extreme intent — Home/End across 14 census years
          // is a 6300px scroll, which would feel like a 2s drift if smooth.
          let behavior: ScrollBehavior = 'smooth';
          switch (ev.key) {
            case 'ArrowRight':
            case 'ArrowUp':
              next = Math.min(lastIdx, currentIdx + 1); break;
            case 'ArrowLeft':
            case 'ArrowDown':
              next = Math.max(0, currentIdx - 1); break;
            case 'Home': next = 0; behavior = 'auto'; break;
            case 'End':  next = lastIdx; behavior = 'auto'; break;
          }
          if (next === null) return;
          ev.preventDefault();
          const scrollable = trackHeight - viewportH;
          // Add a hair of margin past the dead-zone so floor() lands on `next`.
          const targetProgress = next / CENSUS.length + 0.5 / CENSUS.length;
          const targetRaw = targetProgress * 0.96 + 0.02;
          window.scrollTo({
            top: trackTop + targetRaw * scrollable,
            behavior,
          });
        });

        measure();
        // Sync to current scroll position on first paint to avoid a 1881
        // flash on hard reloads partway down the page.
        tick();

        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onResize);
      };

      if (reducedMotion.matches) setupDragMode();
      else setupScrollMode();

      // If the user toggles their OS reduced-motion setting mid-session,
      // CSS reacts (slider becomes visible, sticky disengages) but the JS
      // mode was bound on load. Reload so the right listener path runs.
      reducedMotion.addEventListener('change', () => location.reload());
    </script>
  </body>
</html>
