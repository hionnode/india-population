---
import WorkshopLayout from '../../layouts/WorkshopLayout.astro';
import PresetCard from '../../components/tools/PresetCard.astro';
---

<WorkshopLayout title="The Workshop · Census Atelier">

  <!-- ════════ SHEET HEADER ════════ -->
  <header class="sheet-header">
    <nav class="ws-eyebrow" aria-label="breadcrumb">
      <a href="/">The Census</a>
      <span class="sep">/</span>
      <span class="current">The Workshop</span>
    </nav>
    <div class="sheet-ident" aria-label="sheet identification">
      <span><b>Sheet</b> 00 · 01</span>
      <span><b>Rev.</b> 01</span>
      <span><b>Scale</b> 1 : 1</span>
    </div>
  </header>

  <!-- ════════ MASTHEAD + CARDS ════════ -->
  <main class="ws-masthead">
    <section>
      <h1 class="ws-title">The<br />Work<em>shop</em></h1>
      <span class="ws-title-hi">कार्यशाला</span>
      <p class="ws-lede">
        The tools behind the essay. A drafting table where you can rank, trace,
        and compare a century of Indian census data — and print the result on
        your own letterhead.
      </p>
      <div class="ws-stamp-row" role="note">
        <span><b>Drafted from</b> · Census 1881 – 2011</span>
        <span><b>Draftsman</b> · You</span>
        <span class="stamp-hand">pick an instrument from the wall →</span>
      </div>
    </section>

    <section class="placards" aria-label="tool presets">

      <PresetCard
        preset="bar"
        figure="Fig. B-01 · Bar"
        title="Bar"
        titleEmphasis="Studio"
        hindi="स्तंभ"
        description="Rank states, regions, or seats by any metric — sorted, region-coloured, exportable."
        href="/tools/studio?preset=bar"
      >
        <svg slot="preview" viewBox="0 0 280 60" preserveAspectRatio="none">
          <line x1="0" y1="58" x2="280" y2="58" stroke="#2a3a55" stroke-width="0.5" />
          <rect x="8"   y="6"  width="24" height="52" fill="#8c2e1a" />
          <rect x="40"  y="18" width="24" height="40" fill="#c88a2f" />
          <rect x="72"  y="22" width="24" height="36" fill="#1f4d54" />
          <rect x="104" y="26" width="24" height="32" fill="#1f4d54" />
          <rect x="136" y="30" width="24" height="28" fill="#3d5c3d" />
          <rect x="168" y="32" width="24" height="26" fill="#8c2e1a" />
          <rect x="200" y="36" width="24" height="22" fill="#3d5c3d" />
          <rect x="232" y="40" width="24" height="18" fill="#8c2e1a" />
        </svg>
      </PresetCard>

      <PresetCard
        preset="line"
        figure="Fig. L-01 · Line"
        title="Line"
        titleEmphasis="Studio"
        hindi="रेखा"
        description="Trace a metric across 130 years — absolute, indexed, per-decade growth."
        href="/tools/studio?preset=line"
      >
        <svg slot="preview" viewBox="0 0 280 60" preserveAspectRatio="none">
          <line x1="0" y1="14" x2="280" y2="14" stroke="#2a3a55" stroke-opacity=".18" stroke-dasharray="2 3" />
          <line x1="0" y1="30" x2="280" y2="30" stroke="#2a3a55" stroke-opacity=".18" stroke-dasharray="2 3" />
          <line x1="0" y1="46" x2="280" y2="46" stroke="#2a3a55" stroke-opacity=".18" stroke-dasharray="2 3" />
          <path d="M0,48 C40,48 80,46 120,40 S200,22 280,6"  fill="none" stroke="#8c2e1a" stroke-width="2" />
          <path d="M0,50 C40,50 80,49 120,45 S200,28 280,14" fill="none" stroke="#1f4d54" stroke-width="2" />
          <path d="M0,52 C40,52 80,51 120,48 S200,36 280,22" fill="none" stroke="#c88a2f" stroke-width="2" />
          <path d="M0,54 C40,54 80,53 120,50 S200,40 280,28" fill="none" stroke="#3d5c3d" stroke-width="2" />
          <line x1="0" y1="58" x2="280" y2="58" stroke="#2a3a55" stroke-width="0.5" />
        </svg>
      </PresetCard>

      <PresetCard
        preset="map"
        figure="Fig. M-01 · Map"
        title="Map"
        titleEmphasis="Studio"
        hindi="मानचित्र"
        description="See India as a choropleth — 36 states, any metric, any year."
        href="/tools/studio?preset=map"
      >
        <svg slot="preview" viewBox="0 0 280 60" preserveAspectRatio="xMidYMid meet">
          <g transform="translate(94,3)">
            <path d="M 8,4 L 78,4 L 84,12 L 72,14 L 68,18 L 74,22 L 66,26 L 54,22 L 42,26 L 30,22 L 18,26 L 8,22 Z" fill="#8c2e1a" />
            <path d="M 8,22 L 18,26 L 22,34 L 30,38 L 22,42 L 16,46 L 12,42 L 10,34 Z" fill="#c88a2f" />
            <path d="M 54,22 L 66,26 L 74,22 L 82,24 L 84,30 L 78,34 L 70,32 L 60,28 Z" fill="#1f4d54" />
            <path d="M 30,22 L 42,26 L 54,22 L 60,28 L 54,32 L 42,34 L 30,38 L 22,34 Z" fill="#7a6b55" />
            <path d="M 22,42 L 30,38 L 42,34 L 54,32 L 58,42 L 48,54 L 38,54 L 30,50 Z" fill="#3d5c3d" />
          </g>
        </svg>
      </PresetCard>

      <PresetCard
        preset="compare"
        figure="Fig. C-01 · Compare"
        title="Compare"
        titleEmphasis="Studio"
        hindi="तुलना"
        description="Side-by-side report for 2 – 6 states. Downloadable as PNG, printable as PDF."
        href="/tools/studio?preset=compare"
      >
        <svg slot="preview" viewBox="0 0 280 60" preserveAspectRatio="none">
          <rect x="6"   y="6" width="126" height="48" fill="none" stroke="#2a3a55" stroke-width="0.8" />
          <path d="M 12,46 L 32,30 L 52,36 L 72,20 L 92,14 L 112,10 L 126,12" fill="none" stroke="#8c2e1a" stroke-width="1.6" />
          <line x1="0" y1="6" x2="8" y2="6" stroke="#2a3a55" stroke-width="0.6" />
          <line x1="6" y1="0" x2="6" y2="8" stroke="#2a3a55" stroke-width="0.6" />
          <line x1="139" y1="2" x2="139" y2="58" stroke="#2a3a55" stroke-width="0.4" stroke-dasharray="2 3" />
          <rect x="146" y="6" width="126" height="48" fill="none" stroke="#2a3a55" stroke-width="0.8" />
          <rect x="152" y="34" width="14" height="18" fill="#1f4d54" />
          <rect x="170" y="28" width="14" height="24" fill="#c88a2f" />
          <rect x="188" y="22" width="14" height="30" fill="#3d5c3d" />
          <rect x="206" y="18" width="14" height="34" fill="#8c2e1a" />
          <rect x="224" y="26" width="14" height="26" fill="#7a6b55" />
          <rect x="242" y="30" width="14" height="22" fill="#1f4d54" />
        </svg>
      </PresetCard>

    </section>
  </main>

  <!-- ════════ SHEET FOOTER ════════ -->
  <footer class="sheet-footer">
    <div>
      <span><b>Sources</b> · Census of India · NADA 43333 · State boundaries via GADM / geohacker</span>
    </div>
    <div class="colophon-hand"><em>drafted on cream, grid 16pt, measure blue.</em></div>
    <div><span><b>Drawn</b> · 2026 · 01</span></div>
  </footer>

</WorkshopLayout>
