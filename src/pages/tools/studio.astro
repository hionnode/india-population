---
import WorkshopLayout from '../../layouts/WorkshopLayout.astro';
import ExportBar from '../../components/tools/ExportBar.astro';
import ConfigRail from '../../components/tools/ConfigRail.astro';
import BarStudio from '../../components/tools/BarStudio.astro';
import LineStudio from '../../components/tools/LineStudio.astro';
import MapStudio from '../../components/tools/MapStudio.astro';
import CompareStudio from '../../components/tools/CompareStudio.astro';
import { defaultsFor, type Preset, type StudioState } from '../../scripts/studio';

// Server-side: parse preset from query for the initial SSR state.
// All other state is hydrated client-side from the full URL on mount.
const presetParam = Astro.url.searchParams.get('preset') ?? 'bar';
const preset: Preset = (['bar', 'line', 'map', 'compare'] as Preset[]).includes(presetParam as Preset)
  ? (presetParam as Preset)
  : 'bar';

const initial: StudioState = defaultsFor(preset);

const panelTitles: Record<Preset, { title: string; subtitle: string; fig: string; caption: string }> = {
  bar:     { title: 'Bar Studio',     subtitle: 'स्तंभ',    fig: 'Fig. B-01', caption: 'Bar · studio' },
  line:    { title: 'Line Studio',    subtitle: 'रेखा',     fig: 'Fig. L-01', caption: 'Line · studio' },
  map:     { title: 'Map Studio',     subtitle: 'मानचित्र', fig: 'Fig. M-01', caption: 'Map · studio' },
  compare: { title: 'Compare Studio', subtitle: 'तुलना',    fig: 'Fig. C-01', caption: 'Compare · studio' },
};
---

<WorkshopLayout title={`${panelTitles[preset].title} · The Workshop`}>

  <ExportBar initialPreset={preset} />

  <div class="workspace">

    <ConfigRail initial={initial} />

    <main class="ws-canvas" id="ws-main">

      <!-- Four mutually-exclusive chart panels. Client swaps display based on state.preset. -->

      <BarStudio initialPreset={preset} />
      <LineStudio initialPreset={preset} />
      <MapStudio initialPreset={preset} />
      <CompareStudio initialPreset={preset} />

      <p class="worksheet-note">
        Flip between <em>Bar</em>, <em>Line</em>, <em>Map</em>, and <em>Compare</em> from the chart-type rack on the rail.
        Your selection is encoded in the URL — copy the address bar to share a view.
      </p>

    </main>

  </div>

</WorkshopLayout>

<style>
  body.workshop .placeholder-hint {
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    color: var(--muted);
    text-align: center;
    padding: 120px 20px;
    border: 1px dashed var(--measure-soft);
    background:
      repeating-linear-gradient(
        45deg,
        transparent 0 12px,
        rgba(42, 58, 85, 0.03) 12px 13px
      );
  }
</style>

<script>
  import {
    initStudio,
    requestExportPng,
    printReport,
    copyText,
    showToast,
    citationFor,
    exportDataCsv,
    getStore,
  } from '../../scripts/studio';

  initStudio();

  document.querySelector('[data-action="download-png"]')?.addEventListener('click', () => {
    requestExportPng();
  });
  document.querySelector('[data-action="download-csv"]')?.addEventListener('click', async () => {
    try {
      await exportDataCsv();
      showToast('CSV downloaded');
    } catch (e) {
      console.error('[studio] csv export failed', e);
      showToast('CSV export failed', 'warn');
    }
  });
  document.querySelector('[data-action="print"]')?.addEventListener('click', () => {
    printReport();
  });
  document.querySelector('[data-action="copy-link"]')?.addEventListener('click', async () => {
    const ok = await copyText(window.location.href);
    showToast(ok ? 'Link copied to clipboard' : 'Copy failed — select the address bar instead', ok ? 'info' : 'warn');
  });
  document.querySelector('[data-action="cite"]')?.addEventListener('click', async () => {
    const snippet = citationFor(getStore().snapshot, window.location.href, new Date());
    const ok = await copyText(snippet);
    showToast(ok ? 'Citation copied to clipboard' : 'Copy failed — try again or pick the text manually', ok ? 'info' : 'warn');
  });

  // Sources drawer toggle
  const srcToggle = document.querySelector<HTMLButtonElement>('[data-action="toggle-sources"]');
  const srcDrawer = document.getElementById('ws-sources-drawer');
  const srcClose = document.querySelector<HTMLButtonElement>('[data-action="close-sources"]');
  const openSources = () => {
    if (!srcDrawer || !srcToggle) return;
    srcDrawer.hidden = false;
    srcDrawer.setAttribute('aria-hidden', 'false');
    srcDrawer.classList.add('open');
    srcToggle.setAttribute('aria-expanded', 'true');
    srcClose?.focus();
  };
  const closeSources = () => {
    if (!srcDrawer || !srcToggle) return;
    srcDrawer.classList.remove('open');
    srcDrawer.setAttribute('aria-hidden', 'true');
    srcToggle.setAttribute('aria-expanded', 'false');
    // keep hidden=false during the fade-out, then hide to remove from a11y tree
    window.setTimeout(() => {
      if (!srcDrawer.classList.contains('open')) srcDrawer.hidden = true;
    }, 220);
    srcToggle.focus();
  };
  srcToggle?.addEventListener('click', () => {
    if (srcDrawer?.classList.contains('open')) closeSources();
    else openSources();
  });
  srcClose?.addEventListener('click', closeSources);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && srcDrawer?.classList.contains('open')) closeSources();
  });
  document.addEventListener('click', (e) => {
    if (!srcDrawer?.classList.contains('open')) return;
    const t = e.target as Node;
    if (srcDrawer.contains(t) || srcToggle?.contains(t)) return;
    closeSources();
  });
</script>
